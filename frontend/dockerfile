# Base stage for shared dependencies
FROM node:22-alpine AS base
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install

# Development stage: optimized for hot-reloading
FROM base AS dev
COPY . .
ENV NODE_ENV=development
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# Build stage: prepares the production assets
FROM base AS build
COPY . .
RUN npm run build

# Production stage: minimal runtime image
FROM node:22-alpine AS prod
WORKDIR /app
# We need package.json to run the production server if using adapter-node
COPY --from=build /app/package.json /app/package-lock.json ./
# Install only production dependencies
RUN npm install --omit=dev
# Copy the build output (default for adapter-node is 'build')
COPY --from=build /app/build ./build

ENV NODE_ENV=production
EXPOSE 3000
CMD ["node", "build"]
